# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ─── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string.
# Must match POSTGRES_* values in the root .env (used by the docker-compose db service).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql://training_user:changeme@localhost:5432/training_timer_db

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Must be a long, random string.
# Generate one with: openssl rand -hex 32
JWT_SECRET_KEY=replace-with-output-of-openssl-rand-hex-32

# Signing algorithm — HS256 is the standard default.
JWT_ALGORITHM=HS256

# How long access tokens are valid (in minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=30

# How long refresh tokens are valid (in days).
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# JSON array of allowed frontend origins (pydantic-settings v2 requires JSON array format).
# Development: include all local origins your frontend may run on.
# Production: set to your exact deployed frontend URL (no trailing slash).
#   Example: BACKEND_CORS_ORIGINS=["https://app.example.com"]
# Wildcards are NOT supported when allow_credentials=True.
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ─── App ──────────────────────────────────────────────────────────────────────
# Application environment: development | production
ENV=development

# Enable debug mode (true/false). Keep False in production.
DEBUG=false
