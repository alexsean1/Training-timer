# Copy this file to .env and fill in your values.
# This file is used by Docker Compose to configure the PostgreSQL container.
# Never commit .env to version control.

# ─── PostgreSQL (Docker) ──────────────────────────────────────────────────────
# These values must match DATABASE_URL in backend/.env
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb

# ─── Convenience ─────────────────────────────────────────────────────────────
# Full connection string — used by scripts / tooling outside the backend app
DATABASE_URL=postgresql://appuser:changeme@localhost:5432/appdb
