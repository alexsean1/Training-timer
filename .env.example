# Copy this file to .env and fill in your values.
# This file is used by Docker Compose to configure the PostgreSQL container.
# Never commit .env to version control.

# ─── PostgreSQL (Docker) ──────────────────────────────────────────────────────
# These values must match DATABASE_URL in backend/.env
POSTGRES_USER=training_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=training_timer_db

# ─── Convenience ─────────────────────────────────────────────────────────────
# Full connection string — used by scripts / tooling outside the backend app
DATABASE_URL=postgresql://training_user:changeme@localhost:5432/training_timer_db
